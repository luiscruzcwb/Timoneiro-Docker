FROM golang:1.25-alpine AS builder
RUN apk add --no-cache gcc musl-dev git
WORKDIR /app
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
ENV CGO_ENABLED=0 GOOS=linux
RUN go build -ldflags="-s -w" -buildvcs=false -o /timoneiro-agent ./cmd/agent

FROM alpine:3.19
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /timoneiro-agent /usr/local/bin/timoneiro-agent

EXPOSE 1895
ENV TIMONEIRO_AGENT_PORT=1895

ENTRYPOINT ["/usr/local/bin/timoneiro-agent"]
